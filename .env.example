# =============================================================================
#  proxy-panel 配置模板
#
#  使用方法:
#    cp .env.example .env       # 复制为 .env
#    nano .env                  # 编辑
#    ./start.sh                 # 启动（自动读取 .env）
#
#  也可以通过交互配置向导自动生成:
#    ./start.sh config          # Linux/macOS
#    .\start.ps1 config         # Windows PowerShell
# =============================================================================

# ── 网络 ──────────────────────────────────────────────────────────────────────
# 面板监听地址和端口
# 127.0.0.1:8080 = 仅本地访问（建议配合 Nginx 反代）
# 0.0.0.0:8080   = 所有网卡（注意防火墙）
PANEL_BIND=127.0.0.1:8080

# 订阅链接中的公开主机名（留空 = 取 PANEL_BIND 的 host）
# 如果面板在 Nginx 后面，填实际域名或 IP
# PANEL_PUBLIC_HOST=panel.example.com

# ── 数据库 ────────────────────────────────────────────────────────────────────
# SQLite（推荐，单文件，零配置）
DATABASE_URL=sqlite://./data/panel.db

# PostgreSQL（高并发、多实例场景）
# DATABASE_URL=postgres://panel:password@127.0.0.1:5432/panel

# ── 远程推送 ──────────────────────────────────────────────────────────────────
# dry-run = 模拟执行，不真实连接 SSH（开发 / 演示用）
# ssh     = 真实 SSH 推送，需要配置私钥
PANEL_REMOTE_MODE=dry-run

# SSH 私钥路径（PANEL_REMOTE_MODE=ssh 时必填）
# 对应公钥需要提前放进目标 VPS 的 authorized_keys
PANEL_SSH_KEY=~/.ssh/id_ed25519

# SSH 连接超时（秒）
# PANEL_SSH_CONNECT_TIMEOUT=10

# ── 安全 ──────────────────────────────────────────────────────────────────────
# 管理员初始密码
# 留空 = 首次启动自动生成随机密码并打印到日志
# 设置后仅在 users 表为空时生效（即首次启动）
PANEL_ADMIN_PASSWORD=

# 部署在 HTTPS 反向代理后面时设为 1（启用 Secure Cookie）
# 本地开发保持 0
PANEL_COOKIE_SECURE=0

# Cookie 域（留空 = 自动）
# PANEL_COOKIE_DOMAIN=panel.example.com

# ── 日志 ──────────────────────────────────────────────────────────────────────
# Rust 日志级别过滤
# info,sqlx=warn   推荐生产
# debug            调试
# warn             最安静
RUST_LOG=info,sqlx=warn
